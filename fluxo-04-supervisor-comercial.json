    {
      "id": "preparar-briefing-manha",
      "name": "Preparar Briefing Manha",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        800
      ],
      "parameters": {
        "jsCode": "const event = $('Extrair Telefone Manha').first().json;\nconst leadsRaw = $input.first().json;\nconst leads = Array.isArray(leadsRaw) ? leadsRaw : [leadsRaw];\nconst lead = leads[0];\n\nif (!lead || !lead.id) return [];\n\nconst horario = event.event_start\n  ? new Date(event.event_start).toLocaleTimeString('pt-BR', { timeZone: 'America/Sao_Paulo', hour: '2-digit', minute: '2-digit' })\n  : 'horario nao identificado';\n\nconst contexto = `BRIEFING DE PREPARACAO - reuniao hoje as ${horario}\\n\\nLEAD:\\nNegocio: ${lead.nome_fantasia || lead.nome}\\nSegmento: ${lead.segmento || 'nao informado'}\\nCidade: ${lead.cidade || 'nao informada'}\\nDono/Contato: ${lead.dono || 'nao identificado'}\\nStatus: ${lead.status || 'desconhecido'}\\n\\nHISTORICO DA CONVERSA:\\n${lead.historico_resumido || 'sem historico registrado'}\\n\\nANGULO USADO NA ABORDAGEM:\\n${lead.angulo || 'nao registrado'} - ${lead.conteudo_angulo || ''}\\n\\nRESULTADO QUE BUSCAM:\\n${lead.resultado_alvo || 'nao informado'}\\n\\nLink: ${event.hangout_link || 'verifique o Calendar'}`;\n\nreturn [{ json: { contexto, lead_nome: lead.nome_fantasia || lead.nome } }];"
      }
    },
    {
      "id": "agente-briefing-manha",
      "name": "AGENTE BRIEFING MANHA",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        1760,
        800
      ],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 3000,
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.contexto }}",
        "options": {
          "systemMessage": "Voce e o supervisor comercial da Yonzza Digital. Hoje tem reuniao. Gere o briefing completo para a gestora se preparar bem.\n\nO que incluir:\n- Horario da reuniao e nome do lead\n- Perfil: negocio, segmento, cidade, dono\n- Resumo do que foi discutido ate aqui na conversa\n- Sinais identificados: dores, abertura, objecoes, momento do negocio\n- Angulo usado na abordagem (para nao repetir na reuniao)\n- Sugestao de como abrir a conversa na reuniao\n\nRegras:\n- Tom de supervisor preparando a gestora para uma reuniao importante\n- Direto e util, sem enfeitar\n- Sem markdown, sem emojis, sem tracinho longo\n- Separe blocos com \\\\\n- Maximo 5 blocos, cada um maximo 4 linhas\n\nRetorne APENAS o texto do briefing."
        }
      }
