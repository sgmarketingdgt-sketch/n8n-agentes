    {
      "id": "preparar-notif-reuniao",
      "name": "Preparar Notificação Reunião",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        1200
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst tipo = body.tipo || 'reuniao';\n\n// Bots não geram notificação — info vai no resumo diário\nif (tipo === 'bot_infinito') return [];\n\nconst lead_nome = body.lead_nome || 'Lead';\nconst segmento = body.segmento || '';\nconst cidade = body.cidade || '';\n\nlet msg;\n\nif (tipo === 'contato_humano') {\n  const telefone = body.telefone || 'não informado';\n  const historico = (body.historico || '').replace(/\\[\\[.*?\\]\\]/g, '').trim().substring(0, 300);\n  msg = `🚨 CONTATO PRECISA DA SUA ATENÇÃO\\n\\nEmpresa: ${lead_nome}${segmento ? ' · ' + segmento : ''}\\nWhatsApp do decisor: ${telefone}\\n\\nResumo da conversa:\\n${historico || 'sem histórico disponível'}\\n\\nMotivo: Lead não é o decisor — contato do responsável coletado pelo agente.`;\n} else {\n  const slot_label = body.slot_label || 'horário a confirmar';\n  const hangout_link = body.hangout_link || '';\n  msg = `📅 Reunião agendada agora\\n\\n${lead_nome}${segmento ? ' · ' + segmento : ''}${cidade ? ' · ' + cidade : ''}\\n${slot_label}\\n${hangout_link || 'Acesse o Google Calendar para o link do Meet'}\\n\\nBriefing completo chega hoje pela manhã`;\n}\n\nreturn [{ json: { mensagem: msg } }];"
      }
    },
