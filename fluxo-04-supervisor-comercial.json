    {
      "id": "preparar-alerta",
      "name": "Preparar Contexto Alerta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        400
      ],
      "parameters": {
        "jsCode": "const travadosRaw = $('Buscar Travados Tarde').first().json;\nconst antigosRaw = $input.first().json;\nconst travados = Array.isArray(travadosRaw) ? travadosRaw : [];\nconst antigos = Array.isArray(antigosRaw) ? antigosRaw : [];\n\nconst hoje = new Date().toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo' });\n\nconst travadosInfo = travados.length > 0\n  ? travados.map(l => `${l.nome_fantasia || l.nome} (${l.segmento || '-'}, ${l.cidade || '-'}) parado desde ${new Date(l.updated_at).toLocaleDateString('pt-BR')}`).join('\\n')\n  : 'nenhum';\n\nconst antigosInfo = antigos.length > 0\n  ? antigos.map(l => `${l.nome_fantasia || l.nome} (${l.segmento || '-'}) abordado em ${new Date(l.updated_at).toLocaleDateString('pt-BR')}, follow-up pode ter falhado`).join('\\n')\n  : 'nenhum';\n\nconst contexto = `ALERTA COMERCIAL - ${hoje}\\n\\nQUALIFICANDO TRAVADOS (48h+ sem avanco):\\n${travadosInfo}\\n\\nABORDADOS SEM AVANCO (7+ dias):\\n${antigosInfo}\\n\\nTotal em risco: ${travados.length + antigos.length}`;\n\nreturn [{ json: { contexto, total_em_risco: travados.length + antigos.length } }];"
      }
    },
    {
      "id": "agente-alerta",
      "name": "AGENTE ALERTA TARDE",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
