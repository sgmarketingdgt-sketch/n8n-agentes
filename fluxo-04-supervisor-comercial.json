    {
      "id": "preparar-resumo",
      "name": "Preparar Contexto Resumo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        0
      ],
      "parameters": {
        "jsCode": "const pipeline = $('Buscar Pipeline').first().json;\nconst travadosRaw = $input.first().json;\nconst leads = Array.isArray(pipeline) ? pipeline : [];\nconst travados = Array.isArray(travadosRaw) ? travadosRaw : [];\n\nconst statusCount = {};\nfor (const l of leads) { statusCount[l.status] = (statusCount[l.status] || 0) + 1; }\n\nconst totalBots = leads.filter(l => l.is_bot === true).length;\n\nconst hoje = new Date().toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo' });\nconst agendados = leads.filter(l => l.status === 'agendado');\n\nconst travadosInfo = travados.length > 0\n  ? travados.map(l => `${l.nome_fantasia || l.nome} (${l.segmento || '-'}, ${l.cidade || '-'}) parado desde ${new Date(l.updated_at).toLocaleDateString('pt-BR')}`).join('\\n')\n  : 'nenhum';\n\nconst agendadosInfo = agendados.length > 0\n  ? agendados.map(l => `${l.nome_fantasia || l.nome} (${l.segmento || '-'})`).join('\\n')\n  : 'nenhuma reuniao hoje';\n\nconst botsInfo = totalBots > 0 ? `${totalBots} lead(s) com atendimento automático detectado` : 'nenhum';\n\nconst contexto = `RESUMO DO DIA - ${hoje}\\n\\nPIPELINE:\\nnovo: ${statusCount['novo'] || 0} | abordado: ${statusCount['abordado'] || 0} | qualificando: ${statusCount['qualificando'] || 0} | qualificado: ${statusCount['qualificado'] || 0} | agendado: ${statusCount['agendado'] || 0} | sem_resposta: ${statusCount['sem_resposta'] || 0}\\nTotal ativo: ${leads.length}\\n\\nQUALIFICANDO TRAVADOS (48h+):\\n${travadosInfo}\\n\\nREUNIOES AGENDADAS:\\n${agendadosInfo}\\n\\nBOTS DETECTADOS:\\n${botsInfo}`;\n\nreturn [{ json: { contexto } }];"
      }
    },
    {
      "id": "agente-resumo",
      "name": "AGENTE RESUMO MANHA",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
