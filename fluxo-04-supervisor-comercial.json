    {
      "id": "timestamps-hoje",
      "name": "Timestamps Hoje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        800
      ],
      "parameters": {
        "jsCode": "// Calcula inicio e fim do dia de hoje no fuso BRT (UTC-3)\nconst agora = new Date();\nconst brtOffsetMs = 3 * 60 * 60 * 1000;\nconst brtNow = new Date(agora.getTime() - brtOffsetMs);\nconst startOfTodayBRT = new Date(brtNow);\nstartOfTodayBRT.setUTCHours(0, 0, 0, 0);\nconst startUTC = new Date(startOfTodayBRT.getTime() + brtOffsetMs);\nconst endUTC = new Date(startUTC.getTime() + 24 * 60 * 60 * 1000 - 1);\nreturn [{ json: { time_min: startUTC.toISOString(), time_max: endUTC.toISOString() } }];"
      }
    },
    {
      "id": "listar-reunioes-hoje",
      "name": "Listar Reunioes de Hoje",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [
        440,
        800
      ],
      "parameters": {
        "operation": "getAll",
        "calendar": {
          "__rl": true,
          "value": "agenciayonzza@gmail.com",
          "mode": "id"
        },
        "returnAll": false,
        "limit": 20,
        "options": {
          "timeMin": "={{ $json.time_min }}",
          "timeMax": "={{ $json.time_max }}"
        }
      },
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "CONFIGURE_NO_N8N",
          "name": "Google Calendar Yonzza"
        }
      }
    },
    {
      "id": "filtrar-reunioes-hoje",
      "name": "Filtrar Reunioes Yonzza Hoje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        800
      ],
      "parameters": {
        "jsCode": "const events = $input.all();\nconst reunioes = events\n  .filter(item => item.json.summary && item.json.summary.includes('Triagem'))\n  .map(item => {\n    const ev = item.json;\n    return {\n      json: {\n        event_id: ev.id,\n        event_summary: ev.summary || '',\n        event_description: ev.description || '',\n        event_start: ev.start ? (ev.start.dateTime || ev.start.date) : '',\n        hangout_link: ev.hangoutLink || ''\n      }\n    };\n  });\nif (reunioes.length === 0) return [];\nreturn reunioes;"
      }
    },
    {
      "id": "extrair-tel-manha",
      "name": "Extrair Telefone Manha",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        800
      ],
      "parameters": {
        "jsCode": "const event = $input.first().json;\nconst descricao = event.event_description || '';\nconst phoneMatch = descricao.match(/WhatsApp:\\s*([^\\n@]+)/);\nconst telefone = phoneMatch ? phoneMatch[1].trim().replace('@s.whatsapp.net','').replace('@c.us','') : null;\nreturn [{ json: { ...event, telefone } }];"
      }
    },
